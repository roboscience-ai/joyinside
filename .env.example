# 从 JoyInside 控制台 > 开发者中心 > API密钥 获取
JOYINSIDE_ACCESS_KEY=your_access_key
JOYINSIDE_SECRET_KEY=your_secret_key

# 从 个人信息 > 企业信息 获取
JOYINSIDE_VENDOR_ID=your_vendor_id

# 从 应用管理 获取
JOYINSIDE_APP_ID=your_app_id

# 设备注册后获得（设备管理 > 设备 ID 列）
JOYINSIDE_BOT_ID=your_bot_id

# 可选：设备 SN，首次注册时使用
JOYINSIDE_DEVICE_ID=robot-sn-001
